def classify(num):
    if num > 0:
        print("Positive")
    elif num < 0:
        print("Negative")
    else:
        print("Zero")

    if num != 0:
        if num % 2 == 0:
            print("Even")
        else:
            print("Odd")

numbers = [3, -4, 0, 7, 10]

for n in numbers:
    print("Number:", n)
    classify(n)
